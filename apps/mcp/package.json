{
  "name": "@causalops/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "causalops-mcp": "./dist/server.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "inspect": "npx -y @modelcontextprotocol/inspector tsx src/server.ts"
  },
  "dependencies": {
    "@causalops/api": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@trpc/client": "11.0.0-rc.648",
    "superjson": "^2.2.1",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsx": "^4.19.2",
    "typescript": "5.6.3",
    "vitest": "^2.1.5"
  }
}
