{
  "name": "@causalops/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./routers": {
      "types": "./dist/routers/index.d.ts",
      "import": "./dist/routers/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run"
  },
  "dependencies": {
    "@causalops/ingestor": "workspace:*",
    "@causalops/om-client": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.1",
    "@trpc/server": "11.0.0-rc.648",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "eslint": "^9.14.0",
    "tsx": "^4.19.2",
    "typescript": "5.6.3",
    "vitest": "^2.1.5"
  }
}
